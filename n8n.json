    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a cybersecurity document intelligence assistant. Analyze the following cybersecurity-related document and return ONLY a valid JSON object with these exact fields: summary (a 2-3 sentence plain-language summary of the document), classification (one of: critical_alert - an active, severe security incident requiring immediate response; siem_export - a raw log or SIEM data export; vulnerability_scan - a vulnerability or CVE scan report; incident_ticket - a tracked incident or support ticket record; informational - a general security notice with no immediate action needed; other - none of the above), sentiment (positive, neutral, or negative tone of the document), confidence_score (a number from 0.0 to 1.0 reflecting how confident you are in this classification), action_items (a list of concrete, specific follow-up actions the security team should take based on this document), entities (people: full names of any individuals mentioned, organizations: any company, vendor, or team names mentioned, dates: any dates mentioned, amounts: any CVE IDs, IP addresses, host counts, or other quantities mentioned). Document text: {{ JSON.stringify($json.extracted_text).slice(1, -1) }}\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.2,\n    \"responseMimeType\": \"application/json\",\n    \"responseSchema\": {\n      \"type\": \"OBJECT\",\n      \"properties\": {\n        \"summary\": { \"type\": \"STRING\" },\n        \"classification\": { \"type\": \"STRING\", \"enum\": [\"critical_alert\", \"siem_export\", \"vulnerability_scan\", \"incident_ticket\", \"informational\", \"other\"] },\n        \"sentiment\": { \"type\": \"STRING\", \"enum\": [\"positive\", \"neutral\", \"negative\"] },\n        \"confidence_score\": { \"type\": \"NUMBER\" },\n        \"action_items\": { \"type\": \"ARRAY\", \"items\": { \"type\": \"STRING\" } },\n        \"entities\": {\n          \"type\": \"OBJECT\",\n          \"properties\": {\n            \"people\": { \"type\": \"ARRAY\", \"items\": { \"type\": \"STRING\" } },\n            \"organizations\": { \"type\": \"ARRAY\", \"items\": { \"type\": \"STRING\" } },\n            \"dates\": { \"type\": \"ARRAY\", \"items\": { \"type\": \"STRING\" } },\n            \"amounts\": { \"type\": \"ARRAY\", \"items\": { \"type\": \"STRING\" } }\n          },\n          \"required\": [\"people\", \"organizations\", \"dates\", \"amounts\"]\n        }\n      },\n      \"required\": [\"summary\", \"classification\", \"sentiment\", \"confidence_score\", \"action_items\", \"entities\"]\n    }\n  }\n}\n",
        "options": {}
      },
