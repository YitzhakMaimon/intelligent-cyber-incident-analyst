    {
      "parameters": {
        "jsCode": "// 1. Pull the raw JSON text Gemini returned and parse it into an object\nconst rawText = $node['Call Gemini'].json.candidates[0].content.parts[0].text;\nconst geminiData = JSON.parse(rawText);\n\n// 2. Re-emit every value under a fixed, named key so downstream nodes\n//    (enrichment API, Sheets, email) can always pull a specific field\n//    by name (e.g. $json.classification, $json.summary) regardless of\n//    what Gemini actually returned.\nreturn [{\n  json: {\n    summary: geminiData.summary || \"\",                // short human-readable summary of the document\n    classification: geminiData.classification || \"other\", // category: critical_alert / siem_export / vulnerability_scan / incident_ticket / informational / other\n    sentiment: geminiData.sentiment || \"neutral\",       // positive / neutral / negative\n    confidence_score: parseFloat(geminiData.confidence_score) || 0.0, // 0.0-1.0, how sure Gemini is\n    entities: geminiData.entities || { people: [], organizations: [], dates: [], amounts: [] }, // named sub-fields: people, organizations, dates, amounts\n    action_items: geminiData.action_items || [],        // list of recommended follow-up actions\n    filename: $node['Download file'].json.name || \"unknown\",       // original file name, e.g. alert.txt\n    file_type: $node['Download file'].json.fileExtension || \"unknown\" // txt / pdf / docx\n  }\n}];\n"
      },
